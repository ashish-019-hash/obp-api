# Environment Configuration for OBP-API Backend
PORT=8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=obp_api
DB_SSL_MODE=disable

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h

# Authentication Configuration
DIRECT_LOGIN_ENABLED=true
DIRECT_LOGIN_TOKEN_EXPIRY=672h  # 4 weeks
OAUTH_ENABLED=true
OAUTH_TOKEN_EXPIRY=1h
OAUTH2_ENABLED=true
OAUTH2_TOKEN_EXPIRY=1h
GATEWAY_LOGIN_ENABLED=false

# Security Configuration
MAX_BAD_LOGIN_ATTEMPTS=5
USER_LOCK_DURATION=30m
BCRYPT_COST=12
CONTEXT_RETENTION_DAYS=30
CONSENT_TOKEN_EXPIRY=1h
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_SPECIAL=true
SESSION_TIMEOUT=30m

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ANONYMOUS_PER_MINUTE=100
RATE_LIMIT_ANONYMOUS_PER_HOUR=1000
RATE_LIMIT_AUTHENTICATED_PER_MINUTE=1000
RATE_LIMIT_AUTHENTICATED_PER_HOUR=10000
RATE_LIMIT_CONSUMER_SPECIFIC=true

# Certificate Configuration
REQUIRE_CLIENT_CERTIFICATE=false
CERTIFICATE_KEYSTORE_PATH=
CERTIFICATE_KEYSTORE_PASSWORD=

# OAuth 2.0 / OIDC Configuration
OAUTH2_JWKS_URL=https://accounts.google.com/.well-known/jwks
OAUTH2_ISSUER=https://accounts.google.com
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=

# Berlin Group PSD2 Configuration
BERLIN_GROUP_CONSENT_ENABLED=true
BERLIN_GROUP_API_VERSION=v1.3
PSD2_CERTIFICATE_VALIDATION=true

# Multi-Factor Authentication
MFA_ENABLED=false
MFA_TOTP_ISSUER=OBP-API
MFA_SMS_PROVIDER=
MFA_EMAIL_PROVIDER=

# Advanced Security Features
JWKS_CACHE_DURATION=1h
CERTIFICATE_VALIDATION_ENABLED=true
PSD2_ROLE_VALIDATION=true
HYDRA_ADMIN_URL=
HYDRA_PUBLIC_URL=
